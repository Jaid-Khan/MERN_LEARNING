<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>Login </h1>
    <form action="/login" method="post">
        <input type="number" name="contact" placeholder="contact" id="">
        <input type="password" name="password" placeholder="password" id="">
        <input type="submit" value="Submit">
    </form>
    <script>
      fetch("/check-token",{
        method:"POST"
      })
        .then((res) => {
          return res.json();
        })
        .then((data) => {
        //   console.log(data);
        if(data.res == true){
            window.location.href = "/";
        }
        });
    </script>
  </body>
</html>
